{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Train and Forget",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "/app/host"
                }
            ],
            "justMyCode": false,
            "preLaunchTask": "run-train-and-forget-script"
        }
    ]
}
