# =============================================================================
# SUPREME .env template
# =============================================================================
# Copy this file to .env at the repo root and fill in the values. docker-compose
# loads it via the `env_file: - .env` directive in docker-compose.yml, so every
# variable below is exposed as an environment variable inside the dev container.
# =============================================================================

### WEIGHTS & BIASES ###
# Consumed by src/supreme/utils/wandb_utils/runtime/wandb_setup.py for W&B login.
# WANDB_KEY is your API key from https://wandb.ai/authorize.
WANDB_USERNAME=""
WANDB_KEY=""

#### GITHUB ###
# Consumed by .devcontainer/setup.sh on container start:
#   - GITHUB_EMAIL / GITHUB_USERNAME populate `git config --global user.email/name`
#     so commits made inside the container are attributed correctly.
#   - SSH_KEY is written verbatim to ~/.ssh/id_ed25519 (chmod 600) and used for
#     `git push` over SSH. Paste the FULL key, including the
#     -----BEGIN OPENSSH PRIVATE KEY----- / -----END OPENSSH PRIVATE KEY----- lines,
#     wrapped in double quotes so newlines survive the .env parse.
#     If left empty, setup.sh generates a fresh key and prints it for you to add
#     to your GitHub account + paste back here.
GITHUB_EMAIL=""
GITHUB_USERNAME=""
SSH_KEY=""

#### HF ###
# Consumed by the Hugging Face client (transformers, datasets) for gated-model
# downloads. Generate at https://huggingface.co/settings/tokens (read scope is
# enough for the models SUPREME uses).
HUGGING_FACE_HUB_TOKEN=""

#### SLURM ###
# Consumed by src/supreme/run_slurm.sh as the default `sbatch --account`. Set this to
# your own cluster allocation/account name (override per-run with --account).
SLURM_ACCOUNT=""
